# Supabase Postgres connection string used by Prisma.
# Prefer the Transaction Pooler URL for serverless deployments and direct URL for one-off CLI operations when needed.
# Example format:
# DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DATABASE_URL=""
DIRECT_URL=""

# Optional: enables automated debtor confirmation emails via Resend.
# In Vercel, add these as Production/Preview environment variables.
RESEND_API_KEY=""
CONFIRMATION_EMAIL_FROM="HOAM Warehouse <confirmacao@seudominio.com.br>"
